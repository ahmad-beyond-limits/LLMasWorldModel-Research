# API Keys for LLM Earthquake Multi-Agent Simulation

# 1. OpenAI API Key (Required for GPT-4o/GPT-4o-mini inference)
# Get one at: https://platform.openai.com/
OPENROUTER_API=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemma-4-31b-it:free
# 2. US Census API Key (Required for demographic data like income & education)
# Get one instantly for free at: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your_census_api_key_here

